    <string name="str_user_agreement_liability">5.1 The developer is not responsible for service interruptions or data loss caused by any non-developer reasons such as network conditions, communication lines, server failures, etc.</string>
    <string name="str_user_agreement_modification">6.1 The developer reserves the right to modify this agreement as needed, and modified agreements will be notified through in-app announcements.</string>
    <string name="str_user_agreement_law">7.1 The interpretation, validity, and dispute resolution of this agreement shall be governed by the laws of the People\'s Republic of China.</string>
    <string name="str_user_agreement_update_date">Last updated: April 11, 2026</string>

